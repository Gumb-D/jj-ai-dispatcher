{
  "manifest_version": 3,
  "name": "JJ Dispatcher Browser Connector",
  "version": "1.0.0",
  "description": "Bridges local Dispatcher executions back to ChatGPT visible session.",
  "permissions": [
    "tabs",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "http://127.0.0.1:8787/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
